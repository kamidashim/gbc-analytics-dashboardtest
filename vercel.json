{
  "version": 2,
  "builds": [
    {
      "src": "dashboard/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "telegram-bot/webhook.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/webhook", "dest": "telegram-bot/webhook.js" },
    { "src": "/(.*)", "dest": "dashboard/index.html" }
  ]
}